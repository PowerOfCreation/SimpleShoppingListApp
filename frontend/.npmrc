# Use hoisted node_modules structure for React Native/Expo compatibility
node-linker=hoisted

# Hoist Expo and React Native packages to avoid Metro bundler issues
public-hoist-pattern[]=*expo*
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=@react-native*
public-hoist-pattern[]=@react-navigation*

# Strict peer dependencies (can be set to false if you encounter issues)
strict-peer-dependencies=false
