{
  "name": "sholist",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "packageManager": "pnpm@11.17.0",
  "scripts": {
    "start": "APP_VARIANT=development expo start",
    "start:prod": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "android:dev": "APP_VARIANT=development expo run:android",
    "android:prod": "expo run:android --variant release",
    "android:prod:apk": "expo prebuild --clean && cd android && ./gradlew assembleRelease && cd .. && adb install -r android/app/build/outputs/apk/release/app-release.apk && APP_VARIANT=development expo prebuild --clean",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --coverage --silent",
    "test:ci": "jest --coverage --silent --ci",
    "test:debug": "jest --coverage",
    "lint": "eslint . && tsc --noEmit",
    "lint:fix": "eslint . --fix && tsc --noEmit"
  },
  "dependencies": {
    "@expo/dom-webview": "^56.0.6",
    "@expo/metro-runtime": "56.0.17",
    "@expo/vector-icons": "15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "56.0.16",
    "expo-constants": "56.0.21",
    "expo-dev-client": "~56.0.23",
    "expo-device": "56.0.4",
    "expo-font": "56.0.7",
    "expo-linking": "56.0.15",
    "expo-router": "56.2.15",
    "expo-splash-screen": "56.0.13",
    "expo-sqlite": "56.0.5",
    "expo-status-bar": "56.0.4",
    "expo-system-ui": "56.0.5",
    "expo-web-browser": "56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "2.31.2",
    "react-native-get-random-values": "1.11.0",
    "react-native-popup-menu": "0.16.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "0.21.2",
    "react-native-worklets": "0.8.3",
    "uuid": "11.1.1"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@eslint/compat": "2.1.0",
    "@eslint/eslintrc": "3.3.6",
    "@eslint/js": "9.39.4",
    "@react-native/eslint-plugin": "0.85.3",
    "@testing-library/react-native": "13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "19.2.14",
    "@types/react-test-renderer": "19.1.0",
    "@typescript-eslint/eslint-plugin": "8.60.1",
    "@typescript-eslint/parser": "8.60.1",
    "eslint": "9.39.4",
    "eslint-config-expo": "56.0.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jest": "29.15.2",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-react-native": "4.1.0",
    "expo-build-properties": "56.0.23",
    "expo-doctor": "1.20.1",
    "expo-sqlite-mock": "4.0.0",
    "globals": "15.15.0",
    "jest": "29.7.0",
    "jest-expo": "56.0.5",
    "jest-junit": "17.0.0",
    "prettier": "3.8.3",
    "react-test-renderer": "19.2.3",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "uuid"
        ]
      }
    }
  }
}
